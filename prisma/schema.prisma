generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique(map: "email") @db.VarChar(255)
  name          String   @db.VarChar(100)
  nickname      String?  @db.VarChar(100) // 추가
  gender        String   @db.VarChar(15) // DDL의 enum 대신 String으로 대응 (또는 enum 설정 가능)
  birth         DateTime @db.Date
  address       String?  @db.VarChar(255)
  detailAddress String?  @map("detail_address") @db.VarChar(255)
  phoneNumber   String?  @map("phone_number") @db.VarChar(20)

  userFavorCategories UserFavorCategory[]
  reviews             Review[]
  memberMissions      MemberMission[]

  @@map("user")
}

model FoodCategory {
  id   BigInt @id @default(autoincrement())
  name String @db.VarChar(40)

  restaurants         Restaurant[]
  userFavorCategories UserFavorCategory[]

  @@map("food_category")
}

model Region {
  id   BigInt @id @default(autoincrement())
  name String @db.VarChar(20)

  restaurants Restaurant[]

  @@map("region")
}

model Restaurant {
  id             BigInt   @id @default(autoincrement())
  name           String   @db.VarChar(40)
  runTime        String?  @map("run_time") @db.VarChar(40)
  rAddress       String?  @map("r_address") @db.VarChar(40)
  foodCategoryId BigInt?  @map("food_category_id")
  regionId       BigInt?  @map("region_id")

  foodCategory FoodCategory? @relation(fields: [foodCategoryId], references: [id])
  region       Region?       @relation(fields: [regionId], references: [id])
  missions     Mission[]
  reviews      Review[]

  @@map("restaurant")
}

model Mission {
  id           BigInt   @id @default(autoincrement())
  price        Int?     @map("prcie") // DDL에 prcie라고 오타가 나 있어서 일단 맞췄습니다.
  point        Int?
  passkey      String?  @db.VarChar(10)
  restaurantId BigInt   @map("restaurant_id")

  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  memberMissions MemberMission[]

  @@map("mission")
}

model MemberMission {
  id        BigInt   @id @default(autoincrement())
  memberId  Int      @map("member_id")
  missionId BigInt   @map("mission_id")
  status    String   @default("CHALLENGING") @db.VarChar(15)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  member  User    @relation(fields: [memberId], references: [id])
  mission Mission @relation(fields: [missionId], references: [id])

  @@map("member_mission")
}

model Review {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  restaurantId BigInt   @map("restaurant_id")
  body         String   @db.Text // DB 컬럼명이 body이므로 content에서 body로 변경!
  score        Float    @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@map("review")
}

model UserFavorCategory {
  id             Int          @id @default(autoincrement())
  userId         Int?         @map("user_id")
  foodCategoryId BigInt?      @map("food_category_id")
  
  user         User?         @relation(fields: [userId], references: [id])
  foodCategory FoodCategory? @relation(fields: [foodCategoryId], references: [id])

  @@map("user_favor_category")
  @@unique([userId, foodCategoryId])
}